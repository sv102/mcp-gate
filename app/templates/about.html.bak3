{% extends "base.html" %}{% set page = 'about' %}
{% block title %}About{% endblock %}
{% block content %}
<style>
.about-link{color:var(--accent);text-decoration:underline;text-decoration-color:var(--accent);text-underline-offset:2px}
.about-link:hover{filter:brightness(1.3)}
.crypto-row td{vertical-align:middle}
.crypto-row code{cursor:pointer;font-size:11px;transition:.15s}
.crypto-row code:hover{color:var(--accent)}
</style>
<h1 x-data x-text="'ℹ️ '+($store.i18n?.t('about.title')||'About')"></h1>

<div style="text-align:center;margin-bottom:24px">
  <img src="/assets/oauth-logo.png" alt="MCP-Gate" style="max-width:320px;width:80%;border-radius:12px">
</div>

<div class="grid-2">
  <div class="card"><table>
    <tr><td class="text-muted" style="width:180px" x-data x-text="$store.i18n?.t('about.version')||'Version'"></td><td><code>{{ version }}</code></td></tr>
    <tr><td class="text-muted">Bootstrap</td><td>{% if bootstrap_done %}<span class="badge badge-ok">✓</span>{% else %}<span class="badge badge-err">✗</span>{% endif %}</td></tr>
    <tr><td class="text-muted">Telegram</td><td>{% if telegram_enabled %}<span class="badge badge-ok">on</span>{% else %}<span class="badge badge-warn">off</span>{% endif %}</td></tr>
    <tr><td class="text-muted">Email</td><td>{% if smtp_enabled %}<span class="badge badge-ok">on</span>{% else %}<span class="badge badge-warn">off</span>{% endif %}</td></tr>
    <tr><td class="text-muted" x-data x-text="$store.i18n?.t('about.hosts_count')||'Hosts'"></td><td>{{ hosts_count }}</td></tr>
    <tr><td class="text-muted" x-data x-text="$store.i18n?.t('about.agents_count')||'Agents'"></td><td>{{ agents_count }}</td></tr>
    <tr><td class="text-muted" x-data x-text="$store.i18n?.t('about.sets_count')||'Command sets'"></td><td>{{ sets_count }}</td></tr>
    <tr><td class="text-muted" x-data x-text="$store.i18n?.t('about.secrets_count')||'Secrets'"></td><td>{{ secrets_count }}</td></tr>
    <tr><td class="text-muted" x-data x-text="$store.i18n?.t('about.audit_label')||'Audit log'"></td><td>{{ "%.1f"|format(audit_size / 1024) }} KB</td></tr>
    <tr><td class="text-muted" x-data x-text="$store.i18n?.t('about.data_dir')||'Data'"></td><td><code>{{ data_dir }}</code></td></tr>
  </table></div>

  <div class="card">
    <h2 style="margin-top:0" x-data x-text="'👤 '+($store.i18n?.t('about.author')||'Author')"></h2>
    <table>
      <tr><td class="text-muted" style="width:120px">Copyright</td><td><b>© 2026 Sergey Napalkov (@sv_102)</b></td></tr>
      <tr><td class="text-muted">Telegram</td><td><a class="about-link" href="https://t.me/sv_102" target="_blank">@sv_102</a></td></tr>
      <tr><td class="text-muted">GitHub</td><td><a class="about-link" href="https://github.com/sv102/mcp-gate" target="_blank">sv102/mcp-gate</a></td></tr>
    </table>
    <div class="mt-4" style="font-size:12px;color:var(--text2)">
      <p x-data x-text="$store.i18n?.t('about.about_text')||'MCP Gate — open-source SSH access control for LLM agents. Whitelists, approval workflows, rate limiting, full audit logging.'"></p>
      <p class="mt-2">⭐ <a class="about-link" href="https://github.com/sv102/mcp-gate" target="_blank" x-data x-text="$store.i18n?.t('about.star_text')||'Star on GitHub'"></a></p>
    </div>
    <div class="mt-4" style="border-top:1px solid var(--border);padding-top:12px">
      <h3 style="margin:0 0 8px;font-size:14px" x-data x-text="'☕ '+($store.i18n?.t('about.donate_title')||'Support the project')"></h3>
      <table style="font-size:12px">
        <tr class="crypto-row"><td class="text-muted" style="width:50px">BTC</td><td><code onclick="copyText(this.textContent)">bc1qzg8fgty3306upse4fhl66ltfthyyf9r5guhlle</code></td></tr>
        <tr class="crypto-row"><td class="text-muted">ETH</td><td><code onclick="copyText(this.textContent)">0x6C68fD15B760b3c6a1F981b5e19e25A64b07F603</code></td></tr>
        <tr class="crypto-row"><td class="text-muted">ETC</td><td><code onclick="copyText(this.textContent)">0x061aeA68810500A44bceD5b81Cd2dD3e4Ca0d782</code></td></tr>
        <tr class="crypto-row"><td class="text-muted">TON</td><td><code onclick="copyText(this.textContent)">UQBPijPtuEAPUHrVKbTQKE4We8mOvX1ZMY7XSkruuWklMLN1</code></td></tr>
      </table>
    </div>
  </div>
</div>

<div id="changelog" class="card">
  <h2 x-data x-text="$store.i18n?.t('about.changelog')||'Changelog'"></h2>
  <table>
    <tr><td class="text-muted" style="width:80px"><b>v0.0.7</b></td><td>
      <b>MCP Protocol Transport</b> — SSE + JSON-RPC 2.0 + OAuth 2.0. Claude.ai and other MCP clients connect natively via <code>/sse</code>. OAuth token bound to agent.<br>
      <b>Deny command sets</b> — type <code>deny</code> with highest priority, dark red style (✕).<br>
      <b>INTERSECTION + DENY logic</b> — agent gets only intersection of allow-sets minus deny-sets.<br>
      <b>Fernet API keys</b> — reversible encryption, Show/Hide.<br>
      <b>Toggle switches</b> — sliders everywhere, disabled elements dimmed.<br>
      <b>Hosts: grid/list + Export/Import.</b> i18n updates (ru/en).
    </td></tr>
    <tr><td class="text-muted">v0.0.6</td><td>Agents, parameterized commands, sandbox, duplication, branding.</td></tr>
    <tr><td class="text-muted">v0.0.5</td><td>Parameterized commands (core), custom logo/favicon.</td></tr>
    <tr><td class="text-muted">v0.0.4</td><td>i18n (ru/en), file export, notifications, AGPLv3.</td></tr>
    <tr><td class="text-muted">v0.0.3</td><td>Approval countdown, crypto wallets, nav badge.</td></tr>
    <tr><td class="text-muted">v0.0.1</td><td>Initial: hosts, whitelist, command sets, approvals, Fernet vault, audit, SSH, i18n, themes.</td></tr>
  </table>
</div>

<div class="grid-2">
  <div class="card"><h2 x-data x-text="$store.i18n?.t('about.data_files')||'Data Files'"></h2><table>
    <tr><td class="text-muted">Hosts</td><td><code>/data/hosts.yaml</code></td></tr>
    <tr><td class="text-muted">Agents</td><td><code>/data/agents.yaml</code></td></tr>
    <tr><td class="text-muted">Command Sets</td><td><code>/data/command_sets.yaml</code></td></tr>
    <tr><td class="text-muted">Secrets</td><td><code>/data/secrets.yaml</code></td></tr>
    <tr><td class="text-muted">Config</td><td><code>/data/config.yaml</code></td></tr>
    <tr><td class="text-muted">Audit</td><td><code>/data/audit.jsonl</code></td></tr>
    <tr><td class="text-muted">MCP OAuth</td><td><code>/data/mcp_oauth_tokens.json</code></td></tr>
  </table></div>

  <div class="card">
    <h2 x-data x-text="$store.i18n?.t('about.license_title')||'License'"></h2>
    <div class="stat-card" style="text-align:left;padding:16px;border:1px solid var(--green)">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
        <span style="font-size:20px">📄</span>
        <b style="color:var(--green);font-size:16px">GNU AGPLv3</b>
      </div>
      <p style="font-size:12px;color:var(--text2);margin:0 0 4px">GNU Affero General Public License, Version 3</p>
      <p style="font-size:12px;color:var(--text2);margin:0 0 8px">Copyright © 2026 Sergey Napalkov (@sv_102)</p>
      <p style="font-size:12px;color:var(--text2);margin:0 0 12px" x-data x-text="$store.i18n?.t('about.free_desc')||'Free for self-hosted use. Source code must remain open when modified. Network use counts as distribution.'"></p>
      <div style="font-size:12px;display:flex;flex-wrap:wrap;gap:12px">
        <a class="about-link" href="https://github.com/sv102/mcp-gate/blob/main/LICENSE" target="_blank">View license →</a>
        <a class="about-link" href="https://www.gnu.org/licenses/agpl-3.0.html" target="_blank">AGPLv3 full text →</a>
      </div>
    </div>
  </div>
</div>
{% endblock %}
