# MCP Gate environment variables
# Copy to .env and fill in values

# Required: API authentication token
# Generate with: openssl rand -hex 32
MCP_TOKEN=CHANGE_ME

# Required for Claude.ai / MCP connector: public URL of this instance
# Used for OAuth 2.0 metadata and SSE endpoint discovery
# Example: https://mcp-gate.example.com
MCP_BASE_URL=

# Data directory inside container (usually no need to change)
DATA_DIR=/data
